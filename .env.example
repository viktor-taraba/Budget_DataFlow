# Скопіюйте цей файл у .env і заповніть своїми значеннями.
# Файл .env НЕ комітьте і не завантажуйте нікуди публічно.

# Довільний випадковий рядок (для підпису сесій). Згенерувати можна так:
# python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Пароль, яким ви будете входити у застосунок з телефона
APP_PASSWORD=

# ID вашої Google-таблиці (з URL: https://docs.google.com/spreadsheets/d/ЦЕЙ_ID/edit)
GOOGLE_SHEET_ID=

# Вміст JSON-ключа сервісного акаунта Google, в один рядок (див. README)
GOOGLE_CREDENTIALS_JSON=
