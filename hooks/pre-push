#!/usr/bin/env bash
# Запускається автоматично перед git push (див. README про встановлення).
# Якщо хоч один тест падає — push скасовується.
set -e

echo "🔎 Запускаю тести перед push..."

if [ -x ".venv/bin/python" ]; then
    PYTHON=".venv/bin/python"
else
    PYTHON="python3"
fi

if ! $PYTHON -m pytest -q; then
    echo ""
    echo "❌ Тести не пройшли. Push скасовано."
    echo "   Виправте помилки або запустіть 'pytest -v' для деталей."
    exit 1
fi

echo "✅ Усі тести пройшли — push дозволено."
exit 0
